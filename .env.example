# PokeKeep Environment Configuration Example

# The port the API and web app will be served on inside the container/local machine
PORT=3001

# The file path where the SQLite database will be created/loaded
DB_PATH=./backend/database/pokemon_cards.db

# Optional: Add your Pokémon TCG API Key from https://pokemontcg.io
# This raises your request rate limit from 20,000 to 50,000 queries per day.
POKEMON_TCG_API_KEY=
