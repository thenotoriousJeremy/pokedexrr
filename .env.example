# Pokedexrr Environment Configuration Example

# The port the API and web app will be served on inside the container/local machine
PORT=3001

# The file path where the SQLite database will be created/loaded
DB_PATH=./backend/database/pokemon_cards.db

# Optional: Add your Pokémon TCG API Key from https://pokemontcg.io
# This raises your request rate limit from 20,000 to 50,000 queries per day.
POKEMON_TCG_API_KEY=

# Comma-separated list of origins allowed to call the API (CORS). Defaults to
# the Vite dev server + same-origin production. Set this to your real domain
# when deploying somewhere other than localhost.
CORS_ORIGIN=http://localhost:5173,http://localhost:3001

# Optional: set a known password for the auto-created "admin" account on first
# run. If unset, a random password is generated and printed once to the
# server logs on first startup — check the logs to retrieve it.
DEFAULT_ADMIN_PASSWORD=
